<?xml version="1.0" encoding="UTF-8"?>
<sprites>
  <group object="player">
    <set action="idle">
      <file>player_alt.png</file>
      <fps>2</fps>
      <frame>
        <center>R1:C0</center>
        <extend top="1" />
      </frame>
      <frame>
        <center>R1:C1</center>
        <extend top="1" />
      </frame>
    </set>
    <set action="running">
      <file>player_alt.png</file>
      <fps>8.33</fps>
      <frame>
        <center>R1:C2</center>
        <extend top="1" />
      </frame>
      <frame>
        <center>R1:C3</center>
        <extend top="1" />
      </frame>
      <frame>
        <center>R1:C4</center>
        <extend top="1" />
      </frame>
      <frame>
        <center>R1:C5</center>
        <extend top="1" />
      </frame>
      <frame>
        <center>R1:C6</center>
        <extend top="1" />
      </frame>
    </set>
    <set action="jumping_start">
      <file>player_alt.png</file>
      <frame>
        <center>R3:C0</center>
        <extend top="1" />
      </frame>
    </set>
    <set action="jumping_top_point">
      <file>player_alt.png</file>
      <frame>
        <center>R3:C1</center>
        <extend top="1" />
      </frame>
    </set>
    <set action="falling">
      <file>player_alt.png</file>
      <frame>
        <center>R3:C2</center>
        <extend top="1" />
      </frame>
    </set>
    <set action="landing">
      <file>player_alt.png</file>
      <frame>
        <center>R3:C4</center>
        <extend top="1" left="1" right="1" />
      </frame>
    </set>
  </group>
</sprites>
